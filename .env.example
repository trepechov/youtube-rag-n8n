# ============================================================
# API Keys
# ============================================================

# YouTube Data API v3 — get from https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenRouter — used for BOTH chat LLM (only external API key needed)
# Get key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ============================================================
# LLM Model (OpenRouter)
# Swap freely without restarting — per-request override also supported.
#
# --- Free models (great for local development) ---
# meta-llama/llama-3.1-8b-instruct:free     fast, good quality
# meta-llama/llama-3.2-3b-instruct:free     very fast, lightweight
# google/gemma-2-9b-it:free                 good reasoning
# mistralai/mistral-7b-instruct:free        solid general purpose
# microsoft/phi-3-mini-128k-instruct:free   tiny, surprisingly capable
#
# --- Paid models (for production) ---
# openai/gpt-4o-mini                        fast + cheap
# anthropic/claude-3-haiku                  fast quality
# anthropic/claude-sonnet-4-6               high quality
# meta-llama/llama-3.1-70b-instruct         best open-source
# ============================================================
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ============================================================
# Embeddings (OpenRouter — free, uses OPENROUTER_API_KEY)
# nvidia/llama-nemotron-embed-vl-1b-v2:free  2048 dims, free
# ============================================================
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# ============================================================
# Qdrant
# ============================================================
QDRANT_COLLECTION=podcasts

# ============================================================
# n8n
# ============================================================
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# ============================================================
# PostgreSQL (n8n database)
# ============================================================
POSTGRES_PASSWORD=change_me_strong_password

# ============================================================
# Production only
# ============================================================
DOMAIN=yourdomain.com
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_strong_password

# ============================================================
# Local ports (change if there are conflicts on your machine)
# ============================================================
N8N_PORT=5678
CHAT_API_PORT=8000
SCRAPER_PORT=8001
QDRANT_PORT=6333
